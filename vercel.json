{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(self)"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://fonts.googleapis.com https://www.googletagmanager.com https://plausible.io https://*.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://crecesswagluelvkesul.supabase.co https://api.anthropic.com https://api.resend.com https://www.google-analytics.com https://*.google-analytics.com https://www.googletagmanager.com https://plausible.io; frame-ancestors 'none'"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/login",
      "destination": "/site/login.html"
    },
    {
      "source": "/pricing",
      "destination": "/site/pricing.html"
    },
    {
      "source": "/security",
      "destination": "/site/security.html"
    },
    {
      "source": "/privacy",
      "destination": "/site/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/site/terms.html"
    },
    {
      "source": "/resources",
      "destination": "/site/resources.html"
    },
    {
      "source": "/integrations",
      "destination": "/site/integrations.html"
    },
    {
      "source": "/solutions",
      "destination": "/site/solutions.html"
    },
    {
      "source": "/about",
      "destination": "/site/about.html"
    },
    {
      "source": "/contact",
      "destination": "/site/contact.html"
    },
    {
      "source": "/whats-new",
      "destination": "/site/whats-new.html"
    },
    {
      "source": "/xpa-planning",
      "destination": "/site/xpa-planning.html"
    },
    {
      "source": "/competitors",
      "destination": "/site/competitors.html"
    },
    {
      "source": "/controller",
      "destination": "/site/dashboard/controller.html"
    },
    {
      "source": "/fpa",
      "destination": "/site/dashboard/fpa.html"
    },
    {
      "source": "/workspace",
      "destination": "/site/dashboard/landing.html"
    },
    {
      "source": "/dashboard",
      "destination": "/site/dashboard/live-dashboard.html"
    },
    {
      "source": "/live",
      "destination": "/site/dashboard/live-dashboard.html"
    },
    {
      "source": "/customizer",
      "destination": "/site/dashboard/customizer-v2.html"
    },
    {
      "source": "/cfo",
      "destination": "/site/dashboard/cfo.html"
    },
    {
      "source": "/livedashboard",
      "destination": "/site/dashboard/live-dashboard.html"
    },
    {
      "source": "/workforce",
      "destination": "/site/dashboard/workspace.html"
    }
  ]
}
